public class Lot{
    private int idProduit;
    private int prixAchat;
    private int volume;
    private int prixRevente;
    
    public Lot(int idProduit, int prixAchat, int volume, int prixRevente){
        this.idProduit = idProduit;
        this.prixAchat = prixAchat;
        this.volume = volume;
        this.prixRevente = prixRevente;

    }

    public int getIdProduit(){
        return this.idProduit;
    }

    public int getPrixAchat(){
        return this.prixAchat;
    }

    public int getPrixRevente(){
        return this.prixRevente;
    }

    public int getVolume(){
        return this.volume;
    }

    public int getBenefice(){
        return this.prixRevente - this.prixAchat;
    }

    public float getRatio(){
        return (float) this.getBenefice()/this.getVolume();
    }

    /* instanciation d'une méthode de validation pour la méthode principal */
    public boolean est_Valide(int budgetRestant, int volumeCamionRestant){
        if ((this.prixAchat > budgetRestant)||(this.volume> volumeCamionRestant)){
            return false;
        }
        return true;

    }
    public Lot compareTo(Lot leLot){
        if (leLot.getRatio() > this.getRatio()){
            return leLot;
        }
        else 
            return this;
        
    }
    }
